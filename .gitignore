node_modules/
.DS_Store
*.log
dist/
.aider*

# local agent/editor state — never committed. Without this, dev-push.sh step 2
# (`git add -A`) would sweep ~/.claude local settings into a pushed release.
.claude/
__pycache__/
*.pyc

# zuvo session state (local runtime, not committed)
.zuvo/

# zuvo review reports (local, not committed)
memory/reviews/

# zuvo:leads output (per-user lead lists; not committed)
docs/leads/

# Auto-managed local review queue
docs/review-queue.md
tests/adversarial/.tmp/
# generated by codesift wiki/index — machine-specific, never commit
.codesift/
zuvo/

# zuvo:infra-audit Docker fixtures — never commit private key material or
# the runtime-staged authorized_keys (ensure-fixtures.sh regenerates them).
tests/infra-suite/fixtures/.keys/
tests/infra-suite/fixtures/sshd-*/authorized_keys
