#!/usr/bin/env bash
# ~/.zuvo/append-runlog
#
# Forcing function: blocks `runs.log` append when no matching retro entry
# exists in `retros.log`. Closes the failure mode where agents declare
# "task done" after writing the audit report + Run line, skipping the
# retrospective entirely (observed: 11 db-audit runs Apr 9 → May 4 with
# 0 retro entries).
#
# Usage (call from skills via run-logger.md):
#   echo -e "$RUN_LINE" | ~/.zuvo/append-runlog
#
# Or with explicit args:
#   ~/.zuvo/append-runlog "$RUN_LINE"
#
# Behavior:
#   1. Parse SKILL + PROJECT from the run line (TSV fields 2 + 3).
#   2. Check ~/.zuvo/retros.log for a matching entry (same SKILL +
#      PROJECT, any timestamp). If multiple agents wrote retros, take
#      the most recent.
#   3. If no retro entry: print a clear error to stderr, exit 2, do
#      NOT append to runs.log. Skill caller must write retro first.
#   4. If retro exists: append to runs.log, print confirmation.
#
# Override (escape hatch — use sparingly, audit gate will flag it):
#   ZUVO_SKIP_RETRO_GATE=1 ~/.zuvo/append-runlog "$RUN_LINE"
#
# Skills excluded from gate (no retrospective protocol expected):
#   using-zuvo, backlog, benchmark, agent-benchmark, deploy, canary,
#   worktree (these don't load retrospective.md by design).

set -eu

RUN_LINE="${1:-}"
[ -z "$RUN_LINE" ] && RUN_LINE="$(cat -)"

if [ -z "$RUN_LINE" ]; then
  echo "ERROR: append-runlog received empty input" >&2
  exit 1
fi

# === input normalization + shape guard (2026-05-29 contamination fix) =======
# The runs.log write path previously trusted whatever bytes it was handed,
# which let two corruption classes through: (a) a literal `-e ` prefix when a
# caller used non-POSIX `echo -e` under /bin/sh (runs.log:697), and (b) a
# `Run: ` label prefix copied verbatim from a run-logger.md template
# (runs.log:527). Strip at most one such leading label, reject anything that
# is not a clean 13-field timestamp-led TSV row, and OWN the timestamp so a
# future date can never be forged into the append-only log.
RUN_LINE="${RUN_LINE#Run: }"
RUN_LINE="${RUN_LINE#-e }"
RUN_LINE="${RUN_LINE#RETRO: }"

case "$RUN_LINE" in
  *$'\n'*) echo "RUN_LINE_REJECTED: embedded newline (multi-line collapse) — runs.log NOT appended" >&2; exit 2 ;;
esac

# Field-1 timestamp policy — machine-owned, never agent-forgeable:
#   valid ISO-Z and <= now+300s -> keep (backfill with real git %cI times OK)
#   valid ISO-Z and >  now+300s -> REJECT (kills the fabricated-future class)
#   missing / non-ISO           -> stamp `date -u` now and rebuild the row
_f1=$(printf '%s' "$RUN_LINE" | awk -F'\t' '{print $1}')
case "$_f1" in
  [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]Z)
    _fe=$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$_f1" +%s 2>/dev/null || date -u -d "$_f1" +%s 2>/dev/null || echo "")
    if [ -n "$_fe" ] && [ "$_fe" -gt "$(( $(date +%s) + 300 ))" ]; then
      echo "RUN_LINE_REJECTED: field1 '$_f1' is in the FUTURE (>now+300s) — refusing forged timestamp" >&2
      exit 2
    fi
    ;;
  *)
    RUN_LINE="$(date -u +%Y-%m-%dT%H:%M:%SZ)"$'\t'"${RUN_LINE#*$'\t'}"
    ;;
esac

# Shape guard: exactly 13 TSV fields (12 tabs). A contaminated / column-drifted
# line is REJECTED, never appended (no more `-e ...` / `Run: ...` garbage).
_tabs=$(printf '%s' "$RUN_LINE" | awk -F'\t' '{print NF-1}')
if [ "$_tabs" -ne 12 ]; then
  echo "RUN_LINE_REJECTED: $((_tabs + 1)) TSV fields, runs.log schema requires 13 — NOT appended" >&2
  echo "  Line: $RUN_LINE" >&2
  exit 2
fi

SKILL=$(echo "$RUN_LINE" | awk -F'\t' '{print $2}')
PROJECT=$(echo "$RUN_LINE" | awk -F'\t' '{print $3}')

if [ -z "$SKILL" ] || [ -z "$PROJECT" ]; then
  echo "ERROR: could not parse SKILL/PROJECT from run line:" >&2
  echo "  $RUN_LINE" >&2
  exit 1
fi

# Hermetic-test + distribution override. Two SEPARATE knobs:
#   ZUVO_HOME — STATE dir (runs.log, retros.log). Overridable for tests/builds.
#   ZUVO_BIN  — where helper EXECUTABLES live (verify-audit). Defaults to
#               $HOME/.zuvo independently, so redirecting state for a hermetic
#               test or a Codex/Cursor build does NOT relocate (and thereby
#               silently disable) the audit-verification gate.
# Default preserves the historical $HOME/.zuvo path exactly (no behavior
# change when both are unset). (Codex-cloud memory/ filename harmonization
# is tracked in backlog — out of scope for this change.)
ZUVO_HOME="${ZUVO_HOME:-$HOME/.zuvo}"
ZUVO_BIN="${ZUVO_BIN:-$HOME/.zuvo}"
if ! mkdir -p "$ZUVO_HOME" || [ ! -d "$ZUVO_HOME" ] || [ ! -w "$ZUVO_HOME" ]; then
  echo "ERROR: append-runlog cannot use state dir ZUVO_HOME='$ZUVO_HOME'" >&2
  echo "  (must be a writable directory — set ZUVO_HOME accordingly)" >&2
  exit 1
fi
RUNS_LOG="$ZUVO_HOME/runs.log"
RETROS_LOG="$ZUVO_HOME/retros.log"
SKIP_LOG="$ZUVO_HOME/skip-retro-gate.log"
RUN_START=$(printf '%s' "$RUN_LINE" | awk -F'\t' '{print $1}')
HEAD_SHA7=$(git rev-parse --short HEAD 2>/dev/null || echo "-")

# Portable mkdir-atomic write-lock — same convention as retro-stub (no flock
# dep; macOS ships none). Bounded ZUVO_LOCK_WAIT (default 5s), pid-liveness +
# 30s stale reclaim, fail-SAFE on stat error, PID-guarded release. A unified
# retros.log/runs.log lock across ALL writers is tracked in backlog (B-3).
RUNLOG_LOCK="$ZUVO_HOME/.runlog.lock.d"
_lock_acquire() {
  local waited=0 lpid mt
  while :; do
    if mkdir "$RUNLOG_LOCK" 2>/dev/null; then
      # A lock we cannot stamp ownership of is NOT held: if the pid write
      # fails (full/slow FS) release and retry, so a held lock ALWAYS has a
      # readable pid (the no-pid steal path then only covers a genuine -9
      # between mkdir and echo).
      if echo "$$" > "$RUNLOG_LOCK/pid" 2>/dev/null; then return 0; fi
      rmdir "$RUNLOG_LOCK" 2>/dev/null || true
    fi
    if [ -d "$RUNLOG_LOCK" ]; then
      lpid=$(cat "$RUNLOG_LOCK/pid" 2>/dev/null || echo "")
      mt=$(stat -f %m "$RUNLOG_LOCK" 2>/dev/null || stat -c %Y "$RUNLOG_LOCK" 2>/dev/null || echo "")
      # Correct-by-construction: NEVER steal from a provably-live holder.
      #  - pid present & alive            -> never steal (wait)
      #  - pid present & dead             -> attempt reclaim
      #  - pid absent (-9 between mkdir/echo) -> reclaim only if mtime >30s
      # Reclaim is best-effort and falls THROUGH to the bounded wait+sleep
      # below — it never `continue`s past the guard (a failing rmdir must
      # not busy-spin; the loop stays bounded + paced regardless).
      if [ -n "$lpid" ]; then
        kill -0 "$lpid" 2>/dev/null || { rm -f "$RUNLOG_LOCK/pid" 2>/dev/null || true; rmdir "$RUNLOG_LOCK" 2>/dev/null || true; }
      elif [ -n "$mt" ] && [ "$(( $(date +%s) - mt ))" -gt 30 ]; then
        rmdir "$RUNLOG_LOCK" 2>/dev/null || true
      fi
    fi
    waited=$((waited + 1))
    [ "$waited" -ge "$(( ${ZUVO_LOCK_WAIT:-5} * 5 ))" ] && return 1
    sleep 0.2
  done
}
_lock_release() {
  [ "$(cat "$RUNLOG_LOCK/pid" 2>/dev/null || echo)" = "$$" ] || return 0
  rm -f "$RUNLOG_LOCK/pid" 2>/dev/null || true; rmdir "$RUNLOG_LOCK" 2>/dev/null || true
}
# Append RUN_LINE under the lock and clear the matching run-marker on clean
# completion (so retro-stub --sweep finds no orphan). Exit 4 on lock-busy —
# never a silent drop, never an indefinite hang.
runs_append() {
  if ! _lock_acquire; then
    echo "append-runlog: lock busy (ZUVO_LOCK_WAIT=${ZUVO_LOCK_WAIT:-5}s) — runs.log NOT appended; retry" >&2
    exit 4
  fi
  trap '_lock_release' EXIT INT TERM
  printf '%s\n' "$RUN_LINE" >> "$RUNS_LOG"
  rm -f "$ZUVO_HOME"/run-markers/"$SKILL-$PROJECT"-*.marker 2>/dev/null || true
  _lock_release; trap - EXIT INT TERM
}
# Record a parseable, rotated SKIP: line (consumed by zuvo:context-audit).
skip_log_append() {
  _lock_acquire || { echo "append-runlog: lock busy — skip-retro-gate.log NOT recorded" >&2; return 1; }
  trap '_lock_release' EXIT INT TERM
  [ -f "$SKIP_LOG" ] || printf '# v1 SKIP\tDATE\tSKILL\tPROJECT\tNOTE\n' > "$SKIP_LOG"
  printf 'SKIP:\t%s\t%s\t%s\t%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$SKILL" "$PROJECT" "runs.log gate bypassed" >> "$SKIP_LOG"
  if [ "$(grep -c '^SKIP:' "$SKIP_LOG" 2>/dev/null || echo 0)" -gt 100 ]; then
    T="$SKIP_LOG.tmp.$$.$(date +%s)"
    head -1 "$SKIP_LOG" > "$T"; grep '^SKIP:' "$SKIP_LOG" | tail -n 100 >> "$T"; mv "$T" "$SKIP_LOG"
  fi
  _lock_release; trap - EXIT INT TERM
}

# Skills exempted from retro gate
case "$SKILL" in
  using-zuvo|backlog|benchmark|agent-benchmark|deploy|canary|worktree)
    runs_append
    echo "OK: appended to runs.log (skill '$SKILL' exempt from retro gate)"
    exit 0
    ;;
esac

# Override
if [ "${ZUVO_SKIP_RETRO_GATE:-0}" = "1" ]; then
  runs_append
  echo "WARN: appended to runs.log (ZUVO_SKIP_RETRO_GATE=1 — retro gate bypassed)"
  if skip_log_append; then
    echo "  Recorded to skip-retro-gate.log; flagged by the next zuvo:context-audit / zuvo:retro run."
  else
    echo "  WARNING: skip-retro-gate.log could NOT be recorded (lock busy) — this bypass is UNTRACKED." >&2
  fi
  exit 0
fi

# Verify retros.log has matching entry
if [ ! -f "$RETROS_LOG" ]; then
  echo "RETRO_REQUIRED: ~/.zuvo/retros.log does not exist." >&2
  echo "  Skill '$SKILL' on '$PROJECT' must write a retrospective first." >&2
  echo "  Load shared/includes/retrospective.md, fill 9 fields, append RETRO: line." >&2
  echo "  Then re-run this command." >&2
  exit 2
fi

# Strong-signal match (replaces the loose skill+project-substring/any-date
# match — the exact defect this plan removes). A run is gated ONLY by a FULL
# retro (canonical predicate, retrospective.md): line ^RETRO: AND field2==skill
# AND field3==project (EXACT, not substring) AND field5 NOT a stub value, AND
# — unless ZUVO_MATCH_LOOSE=1 — the retro is for THIS run window: field13==HEAD
# SHA7 OR its timestamp >= the incoming run line's DATE (RUN_START). A stale
# retro or a checkpoint stub therefore never satisfies a fresh completed run.
HAVE_RETRO=$(awk -F'\t' -v skill="$SKILL" -v project="$PROJECT" \
                       -v sha="$HEAD_SHA7" -v rstart="$RUN_START" \
                       -v loose="${ZUVO_MATCH_LOOSE:-0}" '
  # Fail-safe: only a well-formed 17-field record can match. A malformed /
  # column-drifted / extra-tab line is SKIPPED (never satisfies the gate,
  # never falsely blocks — the scan just continues to the next line). This
  # makes $13/timestamp alignment robust against corruption or schema drift.
  /^RETRO:/ && NF==17 {
    if ($2==skill && $3==project &&
        $5!="abandoned" && $5!="context-out" && $5!="partial-recovery") {
      if (loose=="1") { found=1 }
      else {
        # Timestamps are the canonical `%Y-%m-%dT%H:%M:%SZ` (every zuvo
        # writer uses exactly this), so lexicographic >= is correct.
        # Guard: an empty/missing RUN_START must NOT make ts>=rstart
        # always-true (overly permissive) — require the SHA match then.
        ts=$1; sub(/^RETRO: /,"",ts)
        if ($13==sha || (rstart!="" && ts>=rstart)) { found=1 }
      }
    }
  }
  END { print found + 0 }
' "$RETROS_LOG")

if [ "$HAVE_RETRO" -eq 0 ]; then
  echo "RETRO_REQUIRED: No retros.log entry found for skill='$SKILL' project='$PROJECT'." >&2
  echo "" >&2
  echo "  The audit is incomplete without a retrospective." >&2
  echo "  Order of operations:" >&2
  echo "    1. Write the audit report (zuvo/audits/<skill>-<date>.md)." >&2
  echo "    2. Print Validity Gate block." >&2
  echo "    3. Load shared/includes/retrospective.md if not loaded." >&2
  echo "    4. Fill the 9 retrospective fields." >&2
  echo "    5. Append RETRO: line to ~/.zuvo/retros.log." >&2
  echo "    6. Append long-form entry to ~/.zuvo/retros.md." >&2
  echo "    7. THEN call this script (~/.zuvo/append-runlog) for runs.log." >&2
  echo "" >&2
  echo "  Override (use only with cause): ZUVO_SKIP_RETRO_GATE=1" >&2
  exit 2
fi

# === audit-content verification (audit skills only) ===
# For audit-style skills (write a report under zuvo/audits/), every finding must
# cite a real file:line in current code AND carry a Verified-against: <sha>
# stamp. Closes the failure mode where agents copy findings forward from
# prior audits without re-checking against the current working tree.
case "$SKILL" in
  *audit*|review|pentest)
    if [ -x "$ZUVO_BIN/verify-audit" ]; then
      # Locate today's audit report. Common locations:
      #   <project-root>/zuvo/audits/<skill>-YYYY-MM-DD.md
      #   <project-root>/zuvo/audits/<skill>-YYYY-MM-DD-*.md  (variants like -full, -delta)
      AUDIT_DATE=$(date -u +%Y-%m-%d)
      AUDIT_REPORT=""
      # Canonical output dir (see shared/includes/report-output-location.md):
      #   $ZUVO_OUTPUT_DIR, else <project-root>/zuvo. Search the new audits/
      #   location first, then fall back to the legacy audits/ and audit-results/
      #   dirs so in-flight projects mid-migration still pass the gate.
      ZUVO_DIR="${ZUVO_OUTPUT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)/zuvo}"
      for base in "$ZUVO_DIR/audits" "audits" "audit-results"; do
        for candidate in \
          "$base/$SKILL-$AUDIT_DATE.md" \
          $(ls -t "$base"/$SKILL-$AUDIT_DATE*.md 2>/dev/null); do
          if [ -f "$candidate" ]; then
            AUDIT_REPORT="$candidate"
            break 2
          fi
        done
      done
      if [ -z "$AUDIT_REPORT" ]; then
        # No today's report found — try most recent across all locations
        AUDIT_REPORT=$(ls -t "$ZUVO_DIR"/audits/$SKILL-*.md audits/$SKILL-*.md audit-results/$SKILL-*.md 2>/dev/null | head -1)
      fi

      if [ -n "$AUDIT_REPORT" ] && [ -f "$AUDIT_REPORT" ]; then
        if [ "${ZUVO_SKIP_AUDIT_VERIFY:-0}" = "1" ]; then
          echo "WARN: ZUVO_SKIP_AUDIT_VERIFY=1 — finding-content verification bypassed for $AUDIT_REPORT" >&2
        else
          if ! "$ZUVO_BIN/verify-audit" "$AUDIT_REPORT" >&2; then
            echo "" >&2
            echo "AUDIT_REPORT_REJECTED: $AUDIT_REPORT failed finding-content verification." >&2
            echo "  runs.log NOT appended. Fix the findings (add file:line citations + Verified-against: <sha> stamps), then re-run." >&2
            echo "  Override (rare, audited): ZUVO_SKIP_AUDIT_VERIFY=1 ~/.zuvo/append-runlog" >&2
            exit 2
          fi
        fi
      fi
    fi
    ;;
esac

# Retro + audit verified — proceed
runs_append
# When the Stop-hook sweep backfills an orphaned-but-progressed run
# (ZUVO_DEGRADED_AUTOLOG=1, sweep-only — never agent-settable), the matching
# retro carries friction=degraded-autolog and the run NOTES say "auto-logged".
# Those two fields ARE the audit trail (greppable by zuvo:context-audit); no
# separate skip-log line — this row legitimately satisfied the gate via a
# degraded retro, it did NOT bypass it.
if [ "${ZUVO_DEGRADED_AUTOLOG:-0}" = "1" ]; then
  echo "OK: appended to runs.log (DEGRADED-AUTOLOG backfill for $SKILL on $PROJECT — retro never self-executed)"
else
  echo "OK: appended to runs.log (retro verified for $SKILL on $PROJECT)"
fi
