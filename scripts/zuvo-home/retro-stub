#!/usr/bin/env bash
# ~/.zuvo/retro-stub
#
# Checkpoint capture: emit a DEGRADED but enum-valid retro line when a run is
# abandoned / paused / context-out before its terminal retrospective, so
# telemetry survives incomplete runs (the ~50% the terminal-only gate lost).
#
# Schema + predicate are the single source of truth in
# shared/includes/retrospective.md ("Canonical Full-Retro Predicate" /
# "Checkpoint Stub Schema"). This script MUST stay consistent with that doc.
#
# Usage:
#   retro-stub --status=ABANDONED|PARTIAL|CONTEXT_OUT \
#              --skill=<skill> --project=<project> [--friction=<val>] \
#              [--turns=N --tool-calls=N --files-read=N --files-modified=N] \
#              [--missing-template=<text>]
#   retro-stub --sweep   # next-boundary orphan sweep: for each run-marker
#                        # with no matching full retro, emit one ABANDONED
#                        # stub and clear the marker (passive capture).
#
# Lock primitive: a portable mkdir-atomic lock DIR at $ZUVO_HOME/.retro.lock.d
# (NO flock dependency — macOS ships no flock(1)). Bounded ZUVO_LOCK_WAIT
# seconds (default 5); never steal a provably-live holder; a held lock always
# has a readable pid; bounded + paced (no busy-spin); fail-SAFE on stat error.
#
# Idempotent: no-op if a FULL retro (canonical predicate) for the same
# skill+project+SHA7 already exists. A later full retro supersedes a stub.

set -eu

# ---- resolution (mirrors append-runlog: ZUVO_HOME = state dir) -------------
ZUVO_HOME="${ZUVO_HOME:-$HOME/.zuvo}"
if ! mkdir -p "$ZUVO_HOME" || [ ! -d "$ZUVO_HOME" ] || [ ! -w "$ZUVO_HOME" ]; then
  echo "retro-stub: ZUVO_HOME='$ZUVO_HOME' is not a writable directory" >&2
  exit 1
fi
RETRO_LOG="$ZUVO_HOME/retros.log"
RETRO_MD="$ZUVO_HOME/retros.md"
LOCK="$ZUVO_HOME/.retro.lock.d"

# ---- args -----------------------------------------------------------------
STATUS="" FRICTION="" SKILL="" PROJECT="" SWEEP=0
MT="-" TURNS=0 TOOLS=0 FREAD=0 FMOD=0
for a in "$@"; do
  case "$a" in
    --status=*)           STATUS="${a#*=}" ;;
    --friction=*)         FRICTION="${a#*=}" ;;
    --skill=*)            SKILL="${a#*=}" ;;
    --project=*)          PROJECT="${a#*=}" ;;
    --missing-template=*) MT="${a#*=}" ;;
    --turns=*)            TURNS="${a#*=}" ;;
    --tool-calls=*)       TOOLS="${a#*=}" ;;
    --files-read=*)       FREAD="${a#*=}" ;;
    --files-modified=*)   FMOD="${a#*=}" ;;
    --sweep)              SWEEP=1 ;;
    *) echo "retro-stub: unknown arg '$a'" >&2; exit 2 ;;
  esac
done

# PID-guarded lock release (only tears down a lock still OURS). Script-level
# safety net for INT/TERM mid-emit; _emit_one also releases explicitly so the
# lock is never held across sweep iterations.
_release() {
  [ "$(cat "$LOCK/pid" 2>/dev/null || echo)" = "$$" ] || return 0
  rm -f "$LOCK/pid" 2>/dev/null || true; rmdir "$LOCK" 2>/dev/null || true
}
trap '_release' INT TERM EXIT

# ===== _emit_one: locked, idempotent, enum-valid 17-field stub emit ========
# Caller must have set+validated: SKILL PROJECT FRICTION STATUS MT TURNS TOOLS
# FREAD FMOD DATE BRANCH SHA7. Returns 0 (emitted, OR idempotent no-op when a
# full retro for skill+project+SHA7 exists) | 3 (lock busy — nothing written).
_emit_one() {
  local WAIT="${ZUVO_LOCK_WAIT:-5}" acquired=0 waited=0 lpid mt LC EC T
  while :; do
    if mkdir "$LOCK" 2>/dev/null; then
      # A lock we cannot stamp ownership of is NOT held: pid-write failure
      # -> release + retry, so a held lock ALWAYS has a readable pid.
      if echo "$$" > "$LOCK/pid" 2>/dev/null; then acquired=1; break; fi
      rmdir "$LOCK" 2>/dev/null || true
    fi
    if [ -d "$LOCK" ]; then
      lpid=$(cat "$LOCK/pid" 2>/dev/null || echo "")
      mt=$(stat -f %m "$LOCK" 2>/dev/null || stat -c %Y "$LOCK" 2>/dev/null || echo "")
      # NEVER steal a provably-live holder. pid alive -> wait; pid dead ->
      # reclaim (immediate -9 recovery); pid absent (-9 between mkdir/echo)
      # -> reclaim only if mtime >30s; stat-failed + no pid -> fail SAFE.
      # Reclaim is best-effort and FALLS THROUGH to the bounded wait+sleep
      # (never `continue`s past the guard — a failing rmdir must not spin).
      if [ -n "$lpid" ]; then
        kill -0 "$lpid" 2>/dev/null || { rm -f "$LOCK/pid" 2>/dev/null || true; rmdir "$LOCK" 2>/dev/null || true; }
      elif [ -n "$mt" ] && [ "$(( $(date +%s) - mt ))" -gt 30 ]; then
        rmdir "$LOCK" 2>/dev/null || true
      fi
    fi
    waited=$((waited + 1))
    [ "$waited" -ge "$((WAIT * 5))" ] && break
    sleep 0.2
  done
  if [ "$acquired" -ne 1 ]; then
    echo "retro-stub: lock busy (ZUVO_LOCK_WAIT=${WAIT}s), skipped — no data written" >&2
    return 3
  fi

  # idempotency INSIDE the lock (no check-then-act race). Canonical full-retro
  # predicate: well-formed (NF==17) ^RETRO: AND $2==skill AND $3==project
  # (EXACT) AND $13==sha AND $5 NOT a stub value.
  if [ -f "$RETRO_LOG" ] && awk -F'\t' -v s="$SKILL" -v p="$PROJECT" -v sha="$SHA7" '
       /^RETRO:/ && NF==17 {
         if ($2==s && $3==p && $13==sha &&
             $5!="abandoned" && $5!="context-out" && $5!="partial-recovery") { found=1 }
       }
       END { exit found?0:1 }' "$RETRO_LOG"; then
    _release; return 0   # full retro present -> stub is a no-op
  fi

  [ -f "$RETRO_LOG" ] || echo "# v2 DATE SKILL PROJECT CODE_TYPE FRICTION_CATEGORY MISSING_TEMPLATE CONTEXT_GAP TURNS_WASTED TOOL_CALLS FILES_READ FILES_MODIFIED BRANCH SHA7 BLIND_AUDIT ADVERSARIAL CODESIFT ROUTING_STATUS" > "$RETRO_LOG"
  printf 'RETRO: %s\t%s\t%s\tOTHER\t%s\t%s\tnone\t%s\t%s\t%s\t%s\t%s\t%s\tnot_run\tnot_run\tN/A\tN/A\n' \
    "$DATE" "$SKILL" "$PROJECT" "$FRICTION" "$MT" "$TURNS" "$TOOLS" "$FREAD" "$FMOD" "$BRANCH" "$SHA7" >> "$RETRO_LOG"
  LC=$(wc -l < "$RETRO_LOG")
  if [ "$LC" -gt 101 ]; then
    T="$RETRO_LOG.tmp.$$.$(date +%s)"
    head -1 "$RETRO_LOG" > "$T"; tail -n 100 "$RETRO_LOG" >> "$T"; mv "$T" "$RETRO_LOG"
  fi
  {
    printf '<!-- RETRO -->\n\n'
    printf '## [CHECKPOINT-STUB] %s %s %s\n\n' "$DATE" "$SKILL" "$PROJECT"
    printf 'status: %s | friction: %s | turns: %s | tool-calls: %s\n' "$STATUS" "$FRICTION" "$TURNS" "$TOOLS"
    printf 'Run did not reach its terminal retrospective. A later full retro for\n'
    printf 'the same retro-session-id supersedes this stub.\n\n'
  } >> "$RETRO_MD"
  EC=$(grep -c '^<!-- RETRO -->' "$RETRO_MD" 2>/dev/null || echo 0)
  if [ "$EC" -gt 100 ]; then
    T="$RETRO_MD.tmp.$$.$(date +%s)"
    awk '/^<!-- RETRO -->/{c++} c>=('"$EC"'-99){print}' "$RETRO_MD" > "$T" && mv "$T" "$RETRO_MD"
  fi
  _release; return 0
}

# ---- sweep mode: passive next-boundary orphan capture ---------------------
if [ "$SWEEP" -eq 1 ]; then
  MDIR="$ZUVO_HOME/run-markers"
  [ -d "$MDIR" ] || exit 0          # nothing to sweep
  DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  rc=0; any=0
  for m in "$MDIR"/*.marker; do
    [ -e "$m" ] || continue          # nullglob-safe (no markers -> no-op)
    any=1
    msk=$(sed -n 's/^skill=//p'   "$m" 2>/dev/null | head -1)
    mpr=$(sed -n 's/^project=//p' "$m" 2>/dev/null | head -1)
    msha=$(sed -n 's/^sha7=//p'   "$m" 2>/dev/null | head -1)
    mbr=$(sed -n 's/^branch=//p'  "$m" 2>/dev/null | head -1)
    mrepo=$(sed -n 's/^repo_root=//p' "$m" 2>/dev/null | head -1)
    mmt=$(stat -f %m "$m" 2>/dev/null || stat -c %Y "$m" 2>/dev/null || echo "")
    # Unparseable / dirty marker: only delete when clearly stale (>7d) so we
    # never race a marker mid-write; otherwise leave it for a later sweep.
    case "$msk$mpr" in *$'\t'*|*$'\n'*|*$'\r'*) msk="" ;; esac
    if [ -z "$msk" ] || [ -z "$mpr" ]; then
      [ -n "$mmt" ] && [ "$(( $(date +%s) - mmt ))" -gt 604800 ] && rm -f "$m"
      continue
    fi
    SHA7="${msha:--}"
    # (a) Completed normally? If a FULL retro for this run already exists,
    #     just clear the marker (any age) — never emit a spurious stub.
    if [ -f "$RETRO_LOG" ] && awk -F'\t' -v s="$msk" -v p="$mpr" -v sha="$SHA7" '
         /^RETRO:/ && NF==17 {
           if ($2==s && $3==p && $13==sha &&
               $5!="abandoned" && $5!="context-out" && $5!="partial-recovery") found=1
         } END { exit found?0:1 }' "$RETRO_LOG"; then
      rm -f "$m"; continue
    fi
    # (b) No full retro. If the marker is YOUNG the run may still be ACTIVE —
    #     do NOT reap it (a later sweep handles it once it ages out or the
    #     run completes). Only markers older than the grace window (default
    #     6h; ZUVO_SWEEP_GRACE) with no full retro are genuinely abandoned.
    #     Use the most CONSERVATIVE (smallest) of file-mtime age / start_ts
    #     age so a still-running run is never mistaken for abandoned.
    GRACE="${ZUVO_SWEEP_GRACE:-21600}"
    case "$GRACE" in (*[!0-9]*|'') GRACE=21600 ;; esac   # numeric guard
    # start_ts (when the RUN began) is the authoritative age signal — the
    # marker is written ONCE at run start so in production its file mtime ≈
    # start_ts. Prefer start_ts; fall back to file mtime only if start_ts is
    # missing/unparseable. (Do NOT min() with file mtime: a freshly *written*
    # marker for an already-old/abandoned run would look young and escape.)
    mts=$(sed -n 's/^start_ts=//p' "$m" 2>/dev/null | head -1)
    age=""
    if [ -n "$mts" ]; then
      se=$(date -u -j -f '%Y-%m-%dT%H:%M:%SZ' "$mts" +%s 2>/dev/null || date -u -d "$mts" +%s 2>/dev/null || echo "")
      [ -n "$se" ] && age=$(( $(date +%s) - se ))
    fi
    [ -z "$age" ] && [ -n "$mmt" ] && age=$(( $(date +%s) - mmt ))
    if [ -z "$age" ] || [ "$age" -le "$GRACE" ]; then
      continue                       # within grace -> possibly active, leave it
    fi
    # ── progress determination (2026-05-29 degraded-backfill) ──────────────
    # The orphan is genuinely past-grace with no full retro. Decide between:
    #   PROGRESSED  -> the run did real work (commits landed on its branch in
    #                  the window) but never self-logged. Emit a gate-PASSABLE
    #                  DEGRADED retro (friction=degraded-autolog) and backfill a
    #                  truthful runs.log row via append-runlog — so the highest-
    #                  volume work is no longer telemetry-invisible.
    #   NO-PROGRESS -> nothing committed. A true no-op abandon: ABANDONED stub,
    #                  NO runs.log row (correct — there is nothing to credit).
    # PROJECT is normalized to the repo basename (NOT a Codex-exported plan
    # slug) so the backfilled row is attributed to the real repository.
    SKILL="$msk"; BRANCH="${mbr:--}"; TURNS=0; TOOLS=0; FREAD=0; FMOD=0
    progressed=0; PROJECT="$mpr"
    if [ -n "$mrepo" ] && git -C "$mrepo" rev-parse --git-dir >/dev/null 2>&1; then
      PROJECT=$(basename "$(git -C "$mrepo" rev-parse --show-toplevel 2>/dev/null || echo "$mpr")")
      # Commits anywhere in the repo since the run started = evidence of work.
      # (Branch-scoped would miss squash/rebase/detached cases; repo-wide since
      # start_ts is the conservative "something happened during this run" signal.)
      if [ -n "$mts" ]; then
        nc=$(git -C "$mrepo" log --oneline --since="$mts" 2>/dev/null | head -1 | wc -l | tr -d ' ')
        [ "${nc:-0}" -ge 1 ] && progressed=1
      fi
    fi
    if [ "$progressed" -eq 1 ]; then
      STATUS="DEGRADED"; FRICTION="degraded-autolog"
      MT=$(printf '%s' "orphan-autolog:$msk" | tr '\t\r\n' '   ' | cut -c1-40)
      if _emit_one; then
        # Degraded retro now present -> backfill the runs.log row truthfully.
        # field1 = run START (real, past) so the time series stays honest;
        # SHA7/BRANCH/PROJECT match the degraded retro so the gate passes.
        # ZUVO_DEGRADED_AUTOLOG=1 is sweep-only (agents cannot set it).
        _AR=$(command -v append-runlog 2>/dev/null || echo "$ZUVO_HOME/append-runlog")
        if [ -x "$_AR" ]; then
          _RL=$(printf '%s\t%s\t%s\t-\t-\tWARN\t-\tauto-logged\tretro never executed\t%s\t%s\t-\t-' \
                  "${mts:-$DATE}" "$SKILL" "$PROJECT" "$BRANCH" "${msha:--}")
          ZUVO_DEGRADED_AUTOLOG=1 "$_AR" "$_RL" >/dev/null 2>&1 || true
        fi
        rm -f "$m"
      else
        rc=$?                        # lock busy -> marker preserved for retry
      fi
    else
      STATUS="ABANDONED"; FRICTION="abandoned"
      MT=$(printf '%s' "orphan-sweep:$msk" | tr '\t\r\n' '   ' | cut -c1-40)
      # Clear the marker ONLY if _emit_one actually handled it (0 = stub
      # emitted OR idempotent no-op because a full retro already exists).
      # On lock-busy (3, nothing written) KEEP the marker so a later sweep
      # retries it — never lose passive capture for an orphan.
      if _emit_one; then
        rm -f "$m"
      else
        rc=$?                        # lock busy -> marker preserved
      fi
    fi
  done
  [ "$any" -eq 1 ] || exit 0
  exit "$rc"
fi

# ---- normal mode: validate args, then emit one ----------------------------
case "$STATUS" in
  ABANDONED)   DEF_FR="abandoned" ;;
  CONTEXT_OUT) DEF_FR="context-out" ;;
  PARTIAL)     DEF_FR="partial-recovery" ;;
  *) echo "retro-stub: --status must be ABANDONED|PARTIAL|CONTEXT_OUT (got '$STATUS')" >&2; exit 2 ;;
esac
case "${FRICTION:-$DEF_FR}" in
  abandoned|context-out|partial-recovery) FRICTION="${FRICTION:-$DEF_FR}" ;;
  *) FRICTION="$DEF_FR" ;;   # ignore non-stub friction; stay enum-valid
esac
[ -n "$SKILL" ]   || { echo "retro-stub: --skill required" >&2; exit 2; }
[ -n "$PROJECT" ] || { echo "retro-stub: --project required" >&2; exit 2; }
for v in "$TURNS" "$TOOLS" "$FREAD" "$FMOD"; do
  case "$v" in (*[!0-9]*|'') echo "retro-stub: integer cols must be numeric" >&2; exit 2 ;; esac
done
# TSV/log-injection guard (identifiers must be clean; MT stripped + capped 40).
case "$SKILL$PROJECT$FRICTION" in
  *$'\t'*|*$'\n'*|*$'\r'*)
    echo "retro-stub: --skill/--project/--friction must not contain TAB/newline/CR" >&2; exit 2 ;;
esac
MT=$(printf '%s' "$MT" | tr '\t\r\n' '   ' | cut -c1-40)
DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
BRANCH=$(git branch --show-current 2>/dev/null || true)
[ -n "$BRANCH" ] || BRANCH="-"   # detached HEAD prints nothing -> "-"
SHA7=$(git rev-parse --short HEAD 2>/dev/null || echo "-")

_emit_one
exit $?
